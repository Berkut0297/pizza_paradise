<Window x:Class="PizzaParadise.Raktar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pizza Paradise – Raktárkezelés"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stílus a zöld színű mennyiség kijelzéshez -->
        <Style x:Key="MennyisegStilus" TargetType="Border">
            <Setter Property="Background" Value="#FFE8F5E9"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0078A6" Offset="0"/>
                <GradientStop Color="#FF004A61" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Felső panel -->
        <DockPanel LastChildFill="True" VerticalAlignment="Top" Height="80" Background="#FF029BCE">
            <TextBlock Text="🍕 Pizza Paradise – Alkalmazotti rendszer"
                       Foreground="White" FontSize="24" Margin="20,0,0,0" Width="636" Height="48"/>
        </DockPanel>

        <!-- Bal oldali navigációs menü -->
        <StackPanel Orientation="Vertical" Width="220" Background="#FF013E56"
                    VerticalAlignment="Stretch" HorizontalAlignment="Left">

            <StackPanel Margin="12,18,12,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                               FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Name="textBlock_nev" Text="Kovács István"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;"
                               FontSize="16" Foreground="#FFD7EAF2" Margin="0,0,8,0"/>
                    <TextBlock Name="textBlock_beosztas" Text="Raktáros"
                               Foreground="#FFD7EAF2" FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <Rectangle Height="1" Fill="#19FFFFFF" Margin="10,0,10,10"/>

            <Button Name="button_rendelesek" Content="Rendelések" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>

            <Button Name="button_raktar" Content="Raktár" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF029BCE" BorderBrush="{x:Null}"/>

            <Button Name="button_kilepes" Content="Kilépés" Margin="10,40,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FFE43A3A" BorderBrush="{x:Null}"/>
        </StackPanel>

        <!-- Fő tartalom -->
        <Border Margin="240,100,20,20" Background="#FFF5F5F5" CornerRadius="8">
            <Grid Margin="20">
                <!-- Cím és kereső -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Raktárkészlet áttekintése" 
                               FontSize="22" FontWeight="Bold" 
                               Grid.Column="0"
                               VerticalAlignment="Center"/>

                    <!-- Kereső mező -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8" 
                            BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="5" Margin="0,0,0,472">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" 
                                       Foreground="#FF666666" Margin="5,3,5,0"
                                       VerticalAlignment="Top" RenderTransformOrigin="0.583,0.196"/>
                            <TextBox Grid.Column="1" Name="textBox_kereses" 
                                     BorderThickness="0" Background="Transparent"
                                     Text="Keresés..." Foreground="#FF999999" Margin="0,3,0,-6"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Készlettáblázat -->
                <DataGrid x:Name="RaktarGrid" AutoGenerateColumns="False" 
                          Margin="0,50,0,110" Background="White" 
                          BorderBrush="#FFDDDDDD" BorderThickness="1"
                          RowHeight="40" AlternatingRowBackground="#FFF9F9F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Termék kód" Width="*" 
                                            Binding="{Binding TermekKod}"/>
                        <DataGridTextColumn Header="Termék név" Width="*" 
                                            Binding="{Binding TermekNev}"/>
                        <DataGridTextColumn Header="Termék leírás" Width="*" 
                                            Binding="{Binding Leiras}"/>
                        <DataGridTextColumn Header="Kategória" Width="*" 
                                            Binding="{Binding Tipus}"/>
                        <DataGridTextColumn Header="Ár" Width="*" 
                                            Binding="{Binding Ar}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Alsó vezérlők -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" 
                            VerticalAlignment="Bottom" Margin="0,0,0,47" Height="58">
                    <!-- Alapanyag hozzáadása -->
                    <Button Name="button_hozzaadas" Content="➕ Új alapanyag" 
                            Width="140" Height="40" Margin="0,0,10,15"
                            Background="#FF029BCE" Foreground="White" 
                            BorderBrush="{x:Null}" FontSize="14"/>

                    <!-- Készlet módosítása -->
                    <Button Name="button_modositas" Content="✏️ Készlet módosítása" 
                            Width="154" Height="40" Margin="0,0,10,15"
                            Background="#FFFFA500" Foreground="White" 
                            BorderBrush="{x:Null}" FontSize="14"/>
                </StackPanel>

                <!-- Alsó információs panel -->
                <Border Grid.Row="1" VerticalAlignment="Bottom" 
                        Background="#FFE8F0F5" CornerRadius="8" 
                        Padding="15" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Alacsony készlet figyelmeztetés -->

                        <!-- Utolsó frissítés -->
                        <TextBlock Name="textBlock_lastUpdate" Grid.Column="1" Text="Utolsó frissítés: 2026.03.05 10:20" 
                                   Foreground="#FF666666" Margin="20,0,0,0"
                                   VerticalAlignment="Center"/>

                        <!-- Összes tétel -->
                        <TextBlock Name="textBlock_osszesTetel" Grid.Column="3" Text="Összes tétel: 24" 
                                   Foreground="#FF029BCE" FontWeight="Bold" 
                                   FontSize="16" Margin="0,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>