<!-- Updated Készletkezelés XAML (konyhai kijelző eltávolítva, műszakbeosztás legalul) -->
<Window x:Class="PizzaParadise.Keszletkezeles"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pizza Paradise – Alkalmazotti felület"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0078A6" Offset="0"/>
                <GradientStop Color="#FF004A61" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <DockPanel LastChildFill="True" VerticalAlignment="Top" Height="80" Background="#FF029BCE">
            <TextBlock Text="🍕 Pizza Paradise – Alkalmazotti rendszer"
                       Foreground="White" FontSize="24" Margin="20,0,0,0" Width="636" Height="48"/>
        </DockPanel>

        <StackPanel Orientation="Vertical" Width="220" Background="#FF013E56"
                    VerticalAlignment="Stretch" HorizontalAlignment="Left">

            <StackPanel Margin="12,18,12,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                               FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Teljes név"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;"
                               FontSize="16" Foreground="#FFD7EAF2" Margin="0,0,8,0"/>
                    <TextBlock Text="Beosztás"
                               Foreground="#FFD7EAF2" FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <Rectangle Height="1" Fill="#19FFFFFF" Margin="10,0,10,10"/>

            <Button Content="Rendelések" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>

            <Button Content="Készletkezelés" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF029BCE" BorderBrush="{x:Null}"/>

            <Button Content="Műszakbeosztás" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>
            
            <Button Content="Kilépés" Margin="10,40,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FFE43A3A" BorderBrush="{x:Null}"/>

        </StackPanel>


        <!-- Tartalmi rész -->
        <Border Margin="240,100,20,20" Background="#FFF5F5F5" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="Készletkezelés" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Szűrősor (Grid, fix oszlopok – semmi nem lóg bele) -->
                <Grid Margin="0,40,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <!-- Kereső -->
                        <ColumnDefinition Width="200"/>
                        <!-- Kategória -->
                        <ColumnDefinition Width="200"/>
                        <!-- Státusz -->
                        <ColumnDefinition Width="*"/>
                        <!-- kitöltő -->
                        <ColumnDefinition Width="120"/>
                        <!-- Frissítés -->
                    </Grid.ColumnDefinitions>

                    <!-- Keresés -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Keresés:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Name="textbox_search" Width="140"/>
                    </StackPanel>

                    <!-- Kategória -->
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Kategória:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="combo_category" Width="130">
                            <ComboBoxItem Content="Mind"/>
                            <ComboBoxItem Content="Alapanyag"/>
                            <ComboBoxItem Content="Feltét"/>
                            <ComboBoxItem Content="Ital"/>
                            <ComboBoxItem Content="Csomagolóanyag"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Státusz -->
                    <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Státusz:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="combo_status" Width="130">
                            <ComboBoxItem Content="Mind"/>
                            <ComboBoxItem Content="Raktáron"/>
                            <ComboBoxItem Content="Alacsony készlet"/>
                            <ComboBoxItem Content="Elfogyott"/>
                            <ComboBoxItem Content="Zárolt"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Kitöltő -->
                    <StackPanel Grid.Column="3"/>

                    <!-- Frissítés -->
                    <Button Name="button_refresh" Content="Frissítés" Width="120" Height="36"
                            Background="#FF029BCE" Foreground="White" BorderBrush="{x:Null}"
                            Grid.Column="4" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Táblázat (azonos margók/méretezés) -->
                <DataGrid Name="grid_inventory" AutoGenerateColumns="False" Margin="0,80,0,100"
                          CanUserAddRows="False" IsReadOnly="True" RowHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cikkszám" Width="*" Binding="{Binding Sku}"/>
                        <DataGridTextColumn Header="Megnevezés" Width="2*" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Kategória" Width="*" Binding="{Binding Category}"/>
                        <DataGridTextColumn Header="Készlet" Width="*" Binding="{Binding Stock}"/>
                        <DataGridTextColumn Header="Egység" Width="*" Binding="{Binding Unit}"/>
                        <DataGridTextColumn Header="Minimum" Width="*" Binding="{Binding MinLevel}"/>
                        <DataGridTextColumn Header="Státusz" Width="*" Binding="{Binding Status}"/>
                        <DataGridTextColumn Header="Utolsó beszállítás" Width="*" Binding="{Binding LastDelivery}"/>
                        <DataGridTextColumn Header="Beszállító" Width="*" Binding="{Binding Supplier}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Alsó gombsor – igazítás megegyezik -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <Button Name="button_new" Content="Új tétel" Width="120" Height="40" Margin="0,0,10,0"
                            Background="#FF027BAA" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_receive" Content="Bevételezés" Width="140" Height="40" Margin="0,0,10,0"
                            Background="#FF027BAA" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_deduct" Content="Kivételezés" Width="140" Height="40" Margin="0,0,10,0"
                            Background="#FF027BAA" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_export" Content="Export" Width="120" Height="40"
                            Background="#FF12A63B" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>