<Window x:Class="PizzaParadise.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pizza Paradise – Bejelentkezés"
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0078A6" Offset="0"/>
                <GradientStop Color="#FF004A61" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <DockPanel VerticalAlignment="Top" Height="80" Background="#FF029BCE">
            <TextBlock Text="🍕 Pizza Paradise – Alkalmazotti rendszer"
                       Foreground="White" FontSize="24" Margin="20,0,0,0" Width="500"/>
        </DockPanel>

        <Border Width="520" Height="346"
                Background="#FFF5F5F5"
                CornerRadius="12"
                Padding="26"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16" HorizontalAlignment="Center">
                    <TextBlock Text="🍕" FontSize="36" HorizontalAlignment="Center"/>
                    <TextBlock Text="Bejelentkezés" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Kérlek add meg a belépési adataidat."
                               Foreground="#7A7A7A"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" CornerRadius="8" Background="White" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE77B;"
                                   Foreground="#8A8A8A" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Name="textbox_user"
                                 FontSize="16"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#333"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" CornerRadius="8" Background="White" Padding="10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE72E;"
                                   Foreground="#8A8A8A" VerticalAlignment="Center"/>

                        <Grid Grid.Column="1">
                            <PasswordBox Name="password_user"
                                         FontSize="16"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#333"
                                         PasswordChar="●"/>
                            <TextBox Name="password_textbox"
                                     FontSize="16"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#333"
                                     Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="3" LastChildFill="False" Margin="0,0,0,6">
                    <CheckBox Name="checkbox_showpassword"
                              Content="Jelszó megjelenítése"
                              Margin="0,0,12,0"/>
                </DockPanel>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="text_error"
                               Foreground="#E43A3A"
                               FontSize="14"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text="Hibás felhasználónév vagy jelszó."/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Name="button_exit"
                                Content="Kilépés"
                                Width="120" Height="42" Margin="0,0,10,0"
                                Background="#FFE43A3A" Foreground="White" BorderBrush="{x:Null}"/>
                        <Button Name="button_login"
                                Content="Bejelentkezés"
                                Width="160" Height="42"
                                Background="#FF029BCE" Foreground="White" BorderBrush="{x:Null}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
