<Window x:Class="PizzaParadise.Muszakbeosztasok"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pizza Paradise – Alkalmazotti felület"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0078A6" Offset="0"/>
                <GradientStop Color="#FF004A61" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <DockPanel VerticalAlignment="Top" Height="80" Background="#FF029BCE">
            <TextBlock Text="🍕 Pizza Paradise – Alkalmazotti rendszer"
                       Foreground="White" FontSize="24" Margin="20,0,0,0" Width="632"/>
        </DockPanel>

        <StackPanel Orientation="Vertical" Width="220" Background="#FF013E56"
                    VerticalAlignment="Stretch" HorizontalAlignment="Left">

            <StackPanel Margin="12,18,12,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                               FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Teljes név"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;"
                               FontSize="16" Foreground="#FFD7EAF2" Margin="0,0,8,0"/>
                    <TextBlock Text="Beosztás"
                               Foreground="#FFD7EAF2" FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <Rectangle Height="1" Fill="#19FFFFFF" Margin="10,0,10,10"/>

            <Button Content="Rendelések" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>

            <!-- swapped order -->
            <Button Content="Készletkezelés" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>
            <Button Content="Műszakbeosztás" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF029BCE" BorderBrush="{x:Null}"/>
            <Button Content="Kilépés" Margin="10,40,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FFE43A3A" BorderBrush="{x:Null}"/>
        </StackPanel>

        <Border Margin="240,100,20,20" Background="#FFF5F5F5" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="Műszakbeosztás" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                <Grid Margin="0,40,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Hét:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="combo_week" Width="110">
                            <ComboBoxItem Content="Aktuális"/>
                            <ComboBoxItem Content="Következő"/>
                            <ComboBoxItem Content="Előző"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Dátum:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Name="date_single" Width="130"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Beosztás:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="combo_role" Width="130">
                            <ComboBoxItem Content="Mind"/>
                            <ComboBoxItem Content="Pincér"/>
                            <ComboBoxItem Content="Szakács"/>
                            <ComboBoxItem Content="Futár"/>
                            <ComboBoxItem Content="Pultos"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="3"/>

                    <Button Name="button_refresh" Content="Frissítés" Width="120" Height="36"
                            Background="#FF029BCE" Foreground="White" BorderBrush="{x:Null}"
                            Grid.Column="4" HorizontalAlignment="Right"/>
                </Grid>

                <DataGrid Name="grid_shifts" AutoGenerateColumns="False" Margin="0,80,0,100"
                          CanUserAddRows="False" IsReadOnly="True" RowHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dolgozó" Width="2*" Binding="{Binding Employee}"/>
                        <DataGridTextColumn Header="Beosztás" Width="*" Binding="{Binding Role}"/>
                        <DataGridTextColumn Header="Dátum" Width="*" Binding="{Binding Date}"/>
                        <DataGridTextColumn Header="Kezdés" Width="*" Binding="{Binding Start}"/>
                        <DataGridTextColumn Header="Vég" Width="*" Binding="{Binding End}"/>
                        <DataGridTextColumn Header="Műszak" Width="*" Binding="{Binding ShiftName}"/>
                        <DataGridTextColumn Header="Megjegyzés" Width="2*" Binding="{Binding Note}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <Button Name="button_add" Content="Új beosztás" Width="140" Height="40" Margin="0,0,10,0"
                            Background="#FF027BAA" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_export" Content="Export" Width="120" Height="40" Margin="0,0,10,0"
                            Background="#FF027BAA" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_print" Content="Nyomtatás" Width="120" Height="40"
                            Background="#FF12A63B" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
