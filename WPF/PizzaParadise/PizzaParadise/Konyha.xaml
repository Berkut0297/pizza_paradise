<Window x:Class="PizzaParadise.Konyha"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pizza Paradise – Alkalmazotti felület"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <!-- Általános lekerekített gombstílus -->
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Háttér -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0078A6" Offset="0"/>
                <GradientStop Color="#FF004A61" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Fejléc -->
        <DockPanel LastChildFill="True" VerticalAlignment="Top" Height="80" Background="#FF029BCE">
            <TextBlock Text="🍕 Pizza Paradise – Alkalmazotti rendszer"
                       Foreground="White" FontSize="24" Margin="20,0,0,0" Width="636" Height="48"/>
        </DockPanel>

        <!-- Bal oldali menü -->
        <StackPanel Orientation="Vertical" Width="220" Background="#FF013E56"
                    VerticalAlignment="Stretch" HorizontalAlignment="Left">

            <!-- 🔹 Felhasználói infó -->
            <StackPanel Margin="12,18,12,12">
                <!-- Név -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                               FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Teszt Elek"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Beosztás -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE821;"
                               FontSize="16" Foreground="#FFD7EAF2" Margin="0,0,8,0"/>
                    <TextBlock Text="Szakács"
                               Foreground="#FFD7EAF2" FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <!-- Választóvonal a profil és a gombok között -->
            <Rectangle Height="1" Fill="#19FFFFFF" Margin="10,0,10,10"/>

            <!-- Gombok (aktuális fül kiemelve) -->
            <Button Content="Rendelések" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>
            <Button Content="Konyhai kijelző" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF029BCE" BorderBrush="{x:Null}"/>
            <Button Content="Műszakbeosztás" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>
            <Button Content="Készletkezelés" Margin="10,10,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FF027BAA" BorderBrush="{x:Null}"/>
            <Button Content="Kilépés" Margin="10,40,10,0" Height="50"
                    FontSize="16" Foreground="White" Background="#FFE43A3A" BorderBrush="{x:Null}"/>
        </StackPanel>

        <!-- Tartalmi rész -->
        <Border Margin="240,100,20,20" Background="#FFF5F5F5" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="Konyhai kijelző" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Rendelések tábla (azonos margókkal/méretekkel) -->
                <DataGrid Name="OrdersGridKitchen" AutoGenerateColumns="False" Margin="0,40,0,100"
                          CanUserAddRows="False" IsReadOnly="True" RowHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rendelés ID" Width="*" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Tétel(ek)" Width="2*" Binding="{Binding Item}"/>
                        <DataGridTextColumn Header="Megjegyzés" Width="2*" Binding="{Binding Note}"/>
                        <DataGridTextColumn Header="Státusz" Width="*" Binding="{Binding Status}"/>
                        <DataGridTextColumn Header="Időpont" Width="*" Binding="{Binding Time}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Alsó gombsor – pontosan ugyanúgy igazítva -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <Button Name="button_refresh" Content="Frissítés" Width="120" Height="40" Margin="0,0,10,0"
                            Background="#FF029BCE" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                    <Button Name="button_ready" Content="Készen" Width="120" Height="40"
                            Background="#FF12A63B" Foreground="White" BorderBrush="{x:Null}" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
